<div class="mb-section{% if section.settings.tint %} mb-section--tint{% endif %}">
  <div class="page-width">
    <div class="mb-head">
      {%- if section.settings.eyebrow != blank -%}<span class="mb-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}<p>{{ section.settings.subheading }}</p>{%- endif -%}
    </div>
    <div class="mb-grid">
      {%- if section.settings.handles != blank -%}
        {%- assign handles = section.settings.handles | split: ',' -%}
        {%- for handle in handles -%}
          {%- assign hp = handle | strip -%}
          {%- assign p = all_products[hp] -%}
          {%- if p != blank -%}{% render 'mb-card', product: p %}{%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- if section.settings.collection != blank -%}
          {%- assign coll = collections[section.settings.collection] -%}
        {%- else -%}
          {%- assign coll = collections.all -%}
        {%- endif -%}
        {%- for product in coll.products limit: section.settings.count -%}
          {% render 'mb-card', product: product %}
        {%- endfor -%}
      {%- endif -%}
    </div>
    {%- if section.settings.button_label != blank -%}
      <div style="text-align:center;margin-top:36px">
        <a class="mb-btn mb-btn--ink mb-btn--lg" href="{{ section.settings.button_link | default: '/collections/all' }}">{{ section.settings.button_label }}</a>
      </div>
    {%- endif -%}
  </div>
</div>
{% schema %}
{
  "name": "MB Featured products",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The menu" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Fan favourites" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Premium recipes built on real, named proteins. Pick your cat's new obsession." },
    { "type": "collection", "id": "collection", "label": "Collection (blank = all)" },
    { "type": "textarea", "id": "handles", "label": "Product handles (comma-separated, overrides collection)" },
    { "type": "range", "id": "count", "label": "Products to show", "min": 3, "max": 12, "step": 3, "default": 6 },
    { "type": "checkbox", "id": "tint", "label": "Tinted background", "default": false },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop all products →" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "MB Featured products" }]
}
{% endschema %}

{%- comment -%} Meow Belle custom hero, blue bleed, brand image, amber CTA {%- endcomment -%}
<div class="mb-hero">
  <div class="page-width mb-hero__grid">
    <div class="mb-hero__copy">
      {%- if section.settings.eyebrow != blank -%}
        <span class="mb-hero__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.pill != blank -%}
        <div><span class="mb-hero__pill">{{ section.settings.pill }}</span></div>
      {%- endif -%}
      <h1 class="mb-hero__title">{{ section.settings.heading }}</h1>
      {%- if section.settings.subheading != blank -%}
        <p class="mb-hero__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: '#' }}" class="button mb-hero__cta">{{ section.settings.button_label }}</a>
      {%- endif -%}
      {%- if section.settings.show_trust -%}
        <div class="mb-hero__trust">
          <div><span class="stars">★★★★★</span><small>{{ section.settings.trust_1 }}</small></div>
          <div><b style="font-size:1.4rem">{{ section.settings.trust_stat }}</b><small>{{ section.settings.trust_2 }}</small></div>
        </div>
      {%- endif -%}
    </div>
    <div class="mb-hero__media">
      <img
        src="{{ 'mb-hero.png' | asset_url }}"
        alt="{{ section.settings.heading | escape }}"
        width="1184" height="864" loading="eager" fetchpriority="high">
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Meow Belle hero",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "🐾 Fresh · Vet-formulated · Now in Bangladesh" },
    { "type": "text", "id": "pill", "label": "Sale pill", "default": "🔥 Launch sale · 20% OFF, code MEOW20" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Real food. Real happy cats." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Premium Reflex Plus & Prostar cat food, real meat first, delivered across Bangladesh." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop the range" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "checkbox", "id": "show_trust", "label": "Show trust row", "default": true },
    { "type": "text", "id": "trust_1", "label": "Trust line 1", "default": "Loved by cat parents" },
    { "type": "text", "id": "trust_stat", "label": "Trust stat", "default": "13+" },
    { "type": "text", "id": "trust_2", "label": "Trust line 2", "default": "premium recipes" }
  ],
  "presets": [{ "name": "Meow Belle hero" }]
}
{% endschema %}

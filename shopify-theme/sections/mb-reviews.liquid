<div class="mb-section{% if section.settings.tint %} mb-section--tint{% endif %}">
  <div class="page-width">
    <div class="mb-head">
      {%- if section.settings.eyebrow != blank -%}<span class="mb-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <div class="mb-reviews">
      {%- for block in section.blocks -%}
        <div class="mb-review" {{ block.shopify_attributes }}>
          <span class="stars">{{ block.settings.stars }}</span>
          <p>"{{ block.settings.text }}"</p>
          <div class="mb-review__who">
            <div class="mb-review__av">{{ block.settings.name | slice: 0 }}</div>
            <div><b>{{ block.settings.name }}</b><small>✓ Verified · {{ block.settings.product }}</small></div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>
{% schema %}
{
  "name": "MB Reviews",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Loved by cats & their humans" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Five-star bowls" },
    { "type": "checkbox", "id": "tint", "label": "Tinted background", "default": true }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "stars", "label": "Stars", "default": "★★★★★" },
        { "type": "text", "id": "name", "label": "Name", "default": "Farhana R." },
        { "type": "text", "id": "product", "label": "Product", "default": "Reflex Plus Kitten" },
        { "type": "textarea", "id": "text", "label": "Review", "default": "My Persian cleared the bowl in one sitting. Coat looks glossier after three weeks too." }
      ]
    }
  ],
  "presets": [
    {
      "name": "MB Reviews",
      "blocks": [
        { "type": "review", "settings": { "stars": "★★★★★", "name": "Farhana R.", "product": "Reflex Plus Kitten", "text": "My Persian is the fussiest eater alive and she cleared the bowl in one sitting. Coat looks glossier after three weeks too." } },
        { "type": "review", "settings": { "stars": "★★★★★", "name": "Rakib H.", "product": "Prostar Adult", "text": "Ordered the Prostar 15 kg for my three cats. Great value, fast delivery, and they're thriving on it." } },
        { "type": "review", "settings": { "stars": "★★★★★", "name": "Nusrat J.", "product": "Reflex Plus Choosy", "text": "The Choosy Salmon is magic. My cat rejected everything for a week and demolished this." } }
      ]
    }
  ]
}
{% endschema %}

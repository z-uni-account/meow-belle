<div class="mb-section{% if section.settings.tint %} mb-section--tint{% endif %}">
  <div class="page-width">
    <div class="mb-head">
      {%- if section.settings.eyebrow != blank -%}<span class="mb-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <div class="mb-values">
      {%- for block in section.blocks -%}
        <div class="mb-value" {{ block.shopify_attributes }}>
          <div class="mb-value__ic">{{ block.settings.icon }}</div>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>
{% schema %}
{
  "name": "MB Value cards",
  "tag": "section",
  "max_blocks": 4,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why Meow Belle" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Food you'd feel good giving" },
    { "type": "checkbox", "id": "tint", "label": "Tinted background", "default": true }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🍗" },
        { "type": "text", "id": "title", "label": "Title", "default": "Real meat first" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Named proteins lead every recipe, never mystery 'animal derivatives'." }
      ]
    }
  ],
  "presets": [
    {
      "name": "MB Value cards",
      "blocks": [
        { "type": "value", "settings": { "icon": "🍗", "title": "Real meat first", "text": "Named proteins lead every recipe, never mystery 'animal derivatives'." } },
        { "type": "value", "settings": { "icon": "🚫", "title": "No nasties", "text": "Hypoallergenic recipes, no artificial colours, flavours or preservatives." } },
        { "type": "value", "settings": { "icon": "🩺", "title": "Vet-formulated", "text": "Complete & balanced nutrition for every life stage." } },
        { "type": "value", "settings": { "icon": "🚚", "title": "To your door", "text": "Fast delivery across Bangladesh. Free over ৳2,000." } }
      ]
    }
  ]
}
{% endschema %}
